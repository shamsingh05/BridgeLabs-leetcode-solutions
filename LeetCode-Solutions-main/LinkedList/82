class Solution {
    public ListNode deleteDuplicates(ListNode head) {
        ListNode dummy = new ListNode(0);
        dummy.next = head;

        ListNode prev = dummy;

        while (head != null) {
            // check duplicates
            if (head.next != null && head.val == head.next.val) {
                int val = head.val;

                // skip all nodes with same value
                while (head != null && head.val == val) {
                    head = head.next;
                }

                prev.next = head; // link to next distinct node
            } else {
                prev = prev.next;
                head = head.next;
            }
        }

        return dummy.next;
    }
}